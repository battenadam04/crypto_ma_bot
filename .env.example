
EXCHANGE=binance_margin # options: kucoin_futures, binance_margin

TELEGRAM_TOKEN = ''
TELEGRAM_CHAT_ID = ''

KUCOIN_API_KEY=
KUCOIN_SECRET_KEY=
KUCOIN_PASSPHRASE=

BINANCE_API_KEY=
BINANCE_SECRET_KEY=
# Use Binance Spot Test Network (margin APIs may not work on testnet)
BINANCE_SANDBOX=false

# Pairs for live: comma-separated. If empty, bot uses last_backtest.json or default list.
CRYPTO_PAIRS=

# Backtest: fallback when get_top_tradable_pairs fails (e.g. CoinGecko blocked)
BACKTEST_PAIRS=
BACKTEST_WIN_RATE_THRESHOLD=55

# Trade sizing
TRADE_CAPITAL=50
TRADE_CAPITAL_PCT=0.25

# Optional: minimum ADX for trend signals (0 = disabled)
MIN_ADX_TREND=0

TRADING_SIGNALS_ONLY=true