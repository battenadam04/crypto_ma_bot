EXCHANGE=binance_margin # options: kucoin, kucoin_futures, binance_margin

TELEGRAM_TOKEN=
TELEGRAM_CHAT_ID=

KUCOIN_API_KEY=
KUCOIN_SECRET_KEY=
KUCOIN_PASSPHRASE=

BINANCE_API_KEY=
BINANCE_SECRET_KEY=
# Use Binance Spot Test Network (margin APIs may not work on testnet)
BINANCE_SANDBOX=false

# Pairs for live: comma-separated. If empty, bot uses last_backtest.json or default list.
CRYPTO_PAIRS=

# Trade sizing
TRADE_CAPITAL=50
TRADE_CAPITAL_PCT=0.25

# Live trading parameters
DEFAULT_LEVERAGE=10
MAX_OPEN_TRADES=3
MAX_LOSSES_PER_SYMBOL=5
ENTRY_BUFFER_PCT=0.05
MAIN_LOOP_INTERVAL_SEC=300

# Signal thresholds
MIN_ADX_TREND=0
RSI_OVERSOLD=35
RSI_OVERBOUGHT=65
RANGE_ADX_THRESHOLD=25

# Backtest parameters
BACKTEST_PAIRS=
BACKTEST_INTERVAL_HOURS=168      # 24=daily, 168=weekly, 720=monthly
BACKTEST_WIN_RATE_THRESHOLD=50   # min win rate % for a pair to pass (default 50; was 55)
BACKTEST_MIN_TRADES=3            # min trades in backtest for pair to qualify (avoids 1-trade flukes)
BACKTEST_MIN_PAIRS=3             # if fewer than this pass threshold, fallback to top N by win rate
BACKTEST_TOP_N_FALLBACK=8        # max pairs to return when using fallback (top by win rate)
BACKTEST_SLIPPAGE_BPS=5
BACKTEST_COMMISSION_BPS=4
BACKTEST_COOLDOWN_BARS=10
BACKTEST_LOOKAHEAD=50
BACKTEST_DAYS=90

# Daily loss protection (0.30 = 30%)
DAILY_LOSS_LIMIT=0.30

TRADING_SIGNALS_ONLY=true