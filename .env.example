# Live / backtest exchange (flip when switching venues; restart the bot so the CCXT client reloads).
# CCXT ids: phemex, binance (margin), kucoin, kucoinfutures
# - phemex → USDT perpetuals (symbols like BTC/USDT:USDT). Use PHEMEX_* keys.
# - binance_margin → USDT margin spot (symbols like BTC/USDT). Use BINANCE_* keys; TP/SL params are KuCoin-style — verify on testnet before live.
EXCHANGE=phemex

TELEGRAM_TOKEN=
TELEGRAM_CHAT_ID=

PHEMEX_API_KEY=
PHEMEX_SECRET=
PHEMEX_SANDBOX=false

KUCOIN_API_KEY=
KUCOIN_SECRET_KEY=
KUCOIN_PASSPHRASE=

BINANCE_API_KEY=
BINANCE_SECRET_KEY=
# Use Binance Spot Test Network (margin APIs may not work on testnet)
BINANCE_SANDBOX=false

# Optional fallback only: live bot uses last_backtest.json pairs (win rate check) first; CRYPTO_PAIRS if that file is empty/missing.
# Backtest pair universe still uses BACKTEST_PAIRS / auto / CRYPTO_PAIRS / defaults (see below).
CRYPTO_PAIRS=

# Trade sizing
TRADE_CAPITAL=50
TRADE_CAPITAL_PCT=0.25

# Live trading parameters
DEFAULT_LEVERAGE=10
MAX_OPEN_TRADES=3
MAX_LOSSES_PER_SYMBOL=5
ENTRY_BUFFER_PCT=0.05
MAIN_LOOP_INTERVAL_SEC=300

# Overnight pause: skip pair scanning in a daily window (Telegram still polls). Saves exchange API calls / CPU.
# After enabling, use /night on | /night off in Telegram (armed state is saved in runtime_config.json).
NIGHT_QUIET_ENABLED=false
NIGHT_QUIET_START_HOUR=22
NIGHT_QUIET_END_HOUR=6
NIGHT_QUIET_TZ=UTC
NIGHT_QUIET_SLEEP_SEC=60
NIGHT_QUIET_ARMED_DEFAULT=true

# Signal timeframe (can also be changed at runtime via Telegram /timeframe)
TIMEFRAME=5m

# Signal thresholds
MIN_ADX_TREND=0
RSI_OVERSOLD=35
RSI_OVERBOUGHT=65
RANGE_ADX_THRESHOLD=25
LIMIT_ENTRY_OFFSET_PCT=0.0015
LIMIT_IDEA_FALLBACK_PCT=0.003

# Backtest parameters
# Optional: comma-separated list for backtest universe when set (wins over CRYPTO_PAIRS and auto-discovery)
BACKTEST_PAIRS=
# true = REQUIRED to use exchange "top" discovery instead of DEFAULT_BACKTEST pairs. (If false/unset, you always get defaults unless BACKTEST_PAIRS or CRYPTO_PAIRS is set.)
# Fills universe from EXCHANGE (Binance margin / Phemex perps / KuCoin futures) using 24h quote volume.
# CoinGecko filters by *market cap* (BACKTEST_COINGECKO_MIN_CAP), not volume. Use MIN_CAP=0 for volume-only top-N.
BACKTEST_AUTO_TOP_PAIRS=false
BACKTEST_TOP_N=20
BACKTEST_MIN_QUOTE_VOLUME=1000000
# Min USD market cap from CoinGecko; set 0 to disable CoinGecko and rank by exchange volume only
BACKTEST_COINGECKO_MIN_CAP=1000000000
BACKTEST_INTERVAL_HOURS=168      # 24=daily, 168=weekly, 720=monthly
BACKTEST_WIN_RATE_THRESHOLD=50   # only pairs with win rate >= this % are traded (no fallback)
BACKTEST_SLIPPAGE_BPS=5
BACKTEST_COMMISSION_BPS=4
BACKTEST_COOLDOWN_BARS=10
BACKTEST_LOOKAHEAD=50
# Calendar depth for OHLCV (5m + 15m HTF); fetch now scales with this — use 21–28+ to avoid single-week noise, 60–90 for smoother stats.
BACKTEST_DAYS=28
BACKTEST_USE_LIMIT_IDEAS=false   # true = evaluate limit-entry ideas alongside normal entries
# Per-pair screening only: true = count LIM proximity signals in win rate (stricter vs threshold; matches live). false = legacy, usually more pairs pass.
BACKTEST_PER_PAIR_LIMIT_FALLBACK=false
BACKTEST_LIMIT_FILL_BARS=3
BACKTEST_MIN_RR_RATIO=2.0
BACKTEST_ENFORCE_RR=false        # true = also require rr_ratio >= BACKTEST_MIN_RR_RATIO
BACKTEST_APPLY_FEES=true         # set false to see gross edge (no slippage/commission in P&L)

# Daily loss protection (0.30 = 30%)
DAILY_LOSS_LIMIT=0.30

TRADING_SIGNALS_ONLY=true